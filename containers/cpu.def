Bootstrap: docker
From: ubuntu:24.04

# ============================================================================
# peclet suite — CPU container (Kokkos OpenMP + Serial, OpenMPI).
#
# A portable, GPU-free image for laptops, CI, and CPU HPC partitions. Bakes the
# toolchain + a bootstrapped Kokkos/ArborX (host-openmp) prefix, then pip-installs
# the sdflow and dem Python modules against it.
#
# Build (from the suite root, so %files can copy the source tree):
#   apptainer build peclet-cpu.sif containers/cpu.def
# Run:
#   apptainer exec peclet-cpu.sif python3 -c "import peclet.flow, peclet.dem, peclet.morton"
#   mpirun -np 4 apptainer exec peclet-cpu.sif python3 your_script.py
#
# See ../docs/DEPLOYMENT.md for the environment matrix and HPC notes.
# ============================================================================

%files
    # Copy the whole suite (submodules must be checked out: git submodule update --init).
    . /opt/peclet

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build git ca-certificates \
        libopenmpi-dev openmpi-bin libomp-dev \
        python3 python3-dev python3-pip python3-venv
    rm -rf /var/lib/apt/lists/*

    cd /opt/peclet
    # Build the pinned Kokkos + ArborX (OpenMP + Serial) into extern/install/host-openmp.
    tools/bootstrap_deps.sh host-openmp

    PREFIX=/opt/peclet/extern/install/host-openmp
    python3 -m pip install --break-system-packages --upgrade pip
    # Build/install each Python package against the host-openmp prefix.
    CMAKE_PREFIX_PATH=$PREFIX python3 -m pip install --break-system-packages /opt/peclet/sdflow
    CMAKE_PREFIX_PATH=$PREFIX python3 -m pip install --break-system-packages \
        --config-settings=cmake.define.DEM_MPI=ON /opt/peclet/dem
    python3 -m pip install --break-system-packages /opt/peclet/morton

%environment
    export OMP_PROC_BIND=spread
    export OMP_PLACES=threads

%labels
    org.opencontainers.title  "peclet (CPU / Kokkos OpenMP)"
    backend                   host-openmp

%runscript
    exec python3 "$@"
