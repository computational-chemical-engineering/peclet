Bootstrap: docker
From: ubuntu:24.04

# ============================================================================
# peclet suite — CPU container (Kokkos OpenMP + Serial, OpenMPI).
#
# A portable, GPU-free image for laptops, CI, and CPU HPC partitions. Bakes the
# toolchain + a bootstrapped Kokkos/ArborX (host-openmp) prefix, then pip-installs
# the sdflow and dem Python modules against it.
#
# Build (from the suite root, so %files can copy the source tree):
#   apptainer build peclet-cpu.sif containers/cpu.def
# Run:
#   apptainer exec peclet-cpu.sif python3 -c "import peclet.flow, peclet.dem, peclet.morton"
#   mpirun -np 4 apptainer exec peclet-cpu.sif python3 your_script.py
#
# See ../docs/DEPLOYMENT.md for the environment matrix and HPC notes.
# ============================================================================

%files
    # Copy the whole suite (submodules must be checked out: git submodule update --init).
    . /opt/peclet

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build git ca-certificates \
        libopenmpi-dev openmpi-bin libomp-dev \
        python3 python3-dev python3-pip python3-venv
    rm -rf /var/lib/apt/lists/*

    # pip on Ubuntu 24.04 is PEP-668 externally-managed (needs --break-system-packages); older bases
    # neither need nor recognise the flag. Detect once and use $PIP everywhere below.
    # Ensure pip is new enough for --config-settings (22.04 bases ship pip 22.0.2 without it; the 24.04
    # base already has it — skip there to avoid the PEP-668 self-uninstall RECORD error).
    python3 -m pip install --help 2>/dev/null | grep -q -- --config-settings || python3 -m pip install --upgrade pip
    PIP="python3 -m pip install"
    python3 -m pip install --help 2>/dev/null | grep -q -- --break-system-packages && PIP="$PIP --break-system-packages"

    cd /opt/peclet
    # Build the pinned Kokkos + ArborX (OpenMP + Serial) into extern/install/host-openmp.
    tools/bootstrap_deps.sh host-openmp

    PREFIX=/opt/peclet/extern/install/host-openmp
    # mpi4py (built against the container OpenMPI) — the distributed Python drivers use it to MPI_Init.
    $PIP mpi4py

    # Build/install each Python package against the host-openmp prefix; the distributed (MPI) step of
    # flow / dem / voro is compiled in so multi-rank runs work (single-node here; multi-node via the
    # host-MPI bind wrapper, see containers/*-run.sh).
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_FLOW_MPI=ON /opt/peclet/flow
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_DEM_MPI=ON /opt/peclet/dem
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_VORO_MPI=ON /opt/peclet/voro
    CMAKE_PREFIX_PATH=$PREFIX $PIP /opt/peclet/core
    $PIP /opt/peclet/morton

%environment
    export OMP_PROC_BIND=spread
    export OMP_PLACES=threads

%labels
    org.opencontainers.title  "peclet (CPU / Kokkos OpenMP)"
    backend                   host-openmp

%runscript
    exec python3 "$@"
