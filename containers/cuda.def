Bootstrap: docker
From: nvidia/cuda:12.6.2-devel-ubuntu22.04

# ============================================================================
# peclet suite — NVIDIA GPU container (Kokkos CUDA + Serial), for Snellius.
#
# Snellius GPU nodes are A100 (sm_80); the H100 partition is sm_90. Set the arch
# at build time (default below targets the A100):
#   A100:  --build-arg is not used by Apptainer; instead pass via env at build:
#          KOKKOS_ARCH=AMPERE80 CUDA_ARCH=80   (default)
#          KOKKOS_ARCH=HOPPER90 CUDA_ARCH=90   (H100)
# The %post below reads these from the build environment (apptainer build
# --env, or export before building).
#
# Build (on a node/host with the CUDA toolkit base image pullable):
#   apptainer build peclet-cuda.sif containers/cuda.def
# Run on Snellius (request a GPU, then):
#   apptainer exec --nv peclet-cuda.sif python3 -c "import peclet.flow as f; print(f.execution_space)"
#   srun apptainer exec --nv peclet-cuda.sif python3 your_script.py
#
# NOTE: the build COMPILES device code for the chosen arch but does not need a
# GPU; running needs --nv (binds the host driver). See ../docs/DEPLOYMENT.md.
# ============================================================================

%files
    . /opt/peclet

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build git ca-certificates \
        wget bzip2 file libnuma-dev libucx-dev \
        python3 python3-dev python3-pip python3-venv
    rm -rf /var/lib/apt/lists/*

    # pip flag differs by base (PEP-668); detect once and use $PIP everywhere below.
    PIP="python3 -m pip install"
    python3 -m pip install --help 2>/dev/null | grep -q -- --break-system-packages && PIP="$PIP --break-system-packages"

    export PATH=/usr/local/cuda/bin:$PATH
    # GPU arch — override via the build environment; defaults to A100 (Snellius).
    export KOKKOS_ARCH="${KOKKOS_ARCH:-AMPERE80}"
    export CUDA_ARCH="${CUDA_ARCH:-80}"
    export CUDA_COMPILER=/usr/local/cuda/bin/nvcc

    # --- CUDA-aware OpenMPI, matching Snellius's OpenMPI/4.1.x-GCC module -------------------------
    # Built --with-cuda so GPU buffers pass straight to MPI. Its 4.1.x ABI lets containers/snellius-run.sh
    # BIND the host OpenMPI + UCX + PMIx at runtime (the Apptainer "hybrid" model) for the real
    # InfiniBand + GPUDirect transport. Pin OMPI_VER to your site's OpenMPI (module show OpenMPI) if it differs.
    OMPI_VER=4.1.6
    cd /tmp
    wget -q "https://download.open-mpi.org/release/open-mpi/v4.1/openmpi-${OMPI_VER}.tar.bz2"
    tar xf "openmpi-${OMPI_VER}.tar.bz2" && cd "openmpi-${OMPI_VER}"
    ./configure --prefix=/opt/openmpi --with-cuda=/usr/local/cuda --with-ucx \
        --enable-mpi1-compatibility --without-verbs >/tmp/ompi_configure.log 2>&1
    make -j"$(nproc)" >/tmp/ompi_make.log 2>&1
    make install >/tmp/ompi_install.log 2>&1
    cd / && rm -rf "/tmp/openmpi-${OMPI_VER}"*
    export PATH=/opt/openmpi/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:${LD_LIBRARY_PATH:-}

    cd /opt/peclet
    tools/bootstrap_deps.sh nvidia-cuda

    PREFIX=/opt/peclet/extern/install/nvidia-cuda
    # mpi4py built against the CUDA-aware OpenMPI just installed.
    $PIP mpi4py

    # flow / dem / voro with their distributed (MPI) step compiled in (multi-GPU via snellius-run.sh).
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_FLOW_MPI=ON /opt/peclet/flow
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_DEM_MPI=ON /opt/peclet/dem
    CMAKE_PREFIX_PATH=$PREFIX $PIP \
        --config-settings=cmake.define.PECLET_VORO_MPI=ON /opt/peclet/voro
    CMAKE_PREFIX_PATH=$PREFIX $PIP /opt/peclet/core
    $PIP /opt/peclet/morton

%environment
    export PATH=/opt/openmpi/bin:/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:${LD_LIBRARY_PATH:-}

%labels
    org.opencontainers.title  "peclet (CUDA / Kokkos)"
    backend                   nvidia-cuda
    target                    "Snellius A100 (sm_80) / A30 sm_80 / H100 sm_90 (set KOKKOS_ARCH/CUDA_ARCH)"
    mpi                       "build: CUDA-aware OpenMPI 4.1.6; run: bind host OpenMPI via snellius-run.sh"

%runscript
    exec python3 "$@"
